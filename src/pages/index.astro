---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/sections/Hero.astro';
import CoreLoop from '@/components/sections/CoreLoop.astro';
import Features from '@/components/sections/Features.astro';
import StatsSection from '@/components/sections/StatsSection.astro';
import AchievementsSection from '@/components/sections/AchievementsSection.astro';
import TechSection from '@/components/sections/TechSection.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
---

<BaseLayout
  title="HyperType - Free Typing Game | Synthwave Typing Shooter"
  description="Fast-paced synthwave typing shooter. Type words to destroy enemies, build streaks, unlock achievements. Play free in your browser."
>
  <Header />
  <main id="main-content">
    <Hero />
    <CoreLoop />
    <Features />
    <StatsSection />
    <AchievementsSection />
    <TechSection />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
