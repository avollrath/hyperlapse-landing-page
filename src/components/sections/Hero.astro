---
import { Image } from 'astro:assets';
import Button from '@/components/ui/Button.astro';
import gameplayScreenshot from '@/assets/images/gameplay-screenshot.webp';

interface Props {
  gameUrl?: string;
}

const { gameUrl = 'https://avollrath.github.io/HyperType/' } = Astro.props;
---

<section class="hero" id="play" aria-label="HyperType hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-inner">
    <p class="eyebrow hero-reveal">// SYNTHWAVE TYPING SHOOTER</p>
    <h1 class="hero-reveal text-glow-cyan">HYPERTYPE: TYPE TO SURVIVE</h1>
    <p class="subtitle hero-reveal">
      A fast-paced synthwave typing shooter. Type words to destroy enemies, build streaks, and chase high scores.
    </p>
    <div class="cta-row hero-reveal">
      <Button href={gameUrl} label="PLAY NOW" />
      <Button href="#about" label="WATCH GAMEPLAY" variant="outline">▷ WATCH GAMEPLAY</Button>
    </div>
    <figure class="screenshot-panel hero-reveal">
      <Image
        src={gameplayScreenshot}
        alt="HyperType gameplay showing pixel-art enemies with word tiles to type, cyberpunk cityscape background, and HUD with score, level, and heart lives"
        loading="eager"
        fetchpriority="high"
        width={1280}
        height={720}
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 78px 0 var(--spacing-section-sm);
    background: var(--color-bg);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% -20%, rgba(0, 214, 255, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 50% 120%, rgba(255, 0, 184, 0.1) 0%, transparent 70%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .eyebrow {
    color: var(--color-cyan);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
  }

  h1 {
    max-width: 980px;
    margin-top: 18px;
    color: var(--color-cyan);
    font-size: clamp(2.55rem, 6vw, 5rem);
    line-height: 1.08;
  }

  .subtitle {
    max-width: 620px;
    margin-top: 24px;
    font-size: clamp(1rem, 1.5vw, 1.1rem);
  }

  .cta-row {
    display: flex;
    gap: 20px;
    margin-top: 34px;
  }

  .screenshot-panel {
    position: relative;
    width: min(100%, 900px);
    margin: 48px 0 0;
    overflow: hidden;
    border: 2px solid var(--color-panel-border-magenta);
    border-radius: 8px;
    background: var(--color-bg-deep);
    animation: pulse-glow-magenta 4s ease-in-out infinite;
  }

  .screenshot-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(to bottom, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.035) 1px, transparent 1px, transparent 4px);
  }

  img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-reveal:nth-child(1) { animation-delay: 0ms; }
  .hero-reveal:nth-child(2) { animation-delay: 160ms; }
  .hero-reveal:nth-child(3) { animation-delay: 320ms; }
  .hero-reveal:nth-child(4) { animation-delay: 480ms; }
  .hero-reveal:nth-child(5) { animation-delay: 640ms; }

  @media (max-width: 767px) {
    .hero { padding-top: 60px; }
    .cta-row {
      width: min(100%, 360px);
      flex-direction: column;
    }
  }
</style>
