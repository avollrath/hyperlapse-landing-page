---
interface Props {
  label: string;
  value: number;
  suffix?: string;
}

const { label, value, suffix = '' } = Astro.props;
---

<div class="stat-counter">
  <span class="stat-label">{label}</span>
  <span class="stat-value text-glow-magenta" data-counter data-target={value} data-suffix={suffix}>0{suffix}</span>
</div>

<style>
  .stat-counter {
    display: grid;
    gap: 10px;
    min-width: 0;
    padding: 8px 12px;
    text-align: center;
  }

  .stat-label {
    color: var(--color-muted);
    font-size: 0.63rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .stat-value {
    color: var(--color-magenta);
    font-size: clamp(1.9rem, 4vw, 2.55rem);
    font-weight: 700;
    line-height: 1;
  }
</style>
